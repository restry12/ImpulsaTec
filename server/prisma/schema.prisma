generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS BASE ───────────────────────────────────────────

model Usuario {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  rol        Rol
  creadoEn   DateTime @default(now())

  estudiante  Estudiante?
  empresa     Empresa?
  administrador Administrador?
}

enum Rol {
  ESTUDIANTE
  EMPRESA
  ADMINISTRADOR
  VISITANTE
}

// ─── COLEGIO ─────────────────────────────────────────────────

model Colegio {
  id         Int      @id @default(autoincrement())
  nombre     String
  comuna     String
  region     String
  logoUrl    String?
  creadoEn   DateTime @default(now())

  administradores Administrador[]
  estudiantes     Estudiante[]
}

// ─── ADMINISTRADOR (es el colegio) ───────────────────────────

model Administrador {
  id         Int      @id @default(autoincrement())
  nombre     String
  usuarioId  Int      @unique
  colegioId  Int

  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  colegio    Colegio  @relation(fields: [colegioId], references: [id])
  posts      Post[]
  comentarios               Comentario[]
  conversaciones            Conversacion[]
  mensajesDirectosEmitidos  MensajeDirecto[] @relation("dm_emisor_admin")
}

// ─── ESTUDIANTE ──────────────────────────────────────────────

model Estudiante {
  id           Int      @id @default(autoincrement())
  nombre       String
  apellido     String
  especialidad String
  descripcion  String?
  fotoUrl      String?
  disponible         Boolean            @default(true)
  tipoDisponibilidad TipoDisponibilidad @default(PASANTIA)
  usuarioId    Int      @unique
  colegioId    Int
  creadoEn     DateTime @default(now())

  usuario      Usuario      @relation(fields: [usuarioId], references: [id])
  colegio      Colegio      @relation(fields: [colegioId], references: [id])
  habilidades  Habilidad[]
  certificaciones Certificacion[]
  postulaciones   Postulacion[]
  contactos       Contacto[]
  posts           Post[]
  comentarios      Comentario[]
  conversaciones1     Conversacion[]  @relation("conv_est1")
  conversaciones2     Conversacion[]  @relation("conv_est2")
  mensajesDirectosEmitidos MensajeDirecto[] @relation("dm_emisor_estudiante")
}

// ─── HABILIDADES Y CERTIFICACIONES ───────────────────────────

model Habilidad {
  id           Int        @id @default(autoincrement())
  nombre       String
  validada     Boolean    @default(false)
  estudianteId Int

  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
}

model Certificacion {
  id             Int        @id @default(autoincrement())
  nombre         String
  institucion    String?
  fechaObtencion DateTime?
  validada       Boolean    @default(false)
  estudianteId   Int

  estudiante     Estudiante @relation(fields: [estudianteId], references: [id])
}

// ─── EMPRESA ─────────────────────────────────────────────────

model Empresa {
  id          Int      @id @default(autoincrement())
  nombre      String
  rubro       String
  descripcion String?
  logoUrl     String?
  usuarioId   Int      @unique
  creadoEn    DateTime @default(now())

  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  ofertas     Oferta[]
  contactos   Contacto[]
  posts       Post[]
  comentarios      Comentario[]
  mensajes    Mensaje[]
  conversaciones      Conversacion[]
  mensajesDirectosEmitidos MensajeDirecto[] @relation("dm_emisor_empresa")
}

// ─── OFERTAS DE PASANTÍA ─────────────────────────────────────

model Oferta {
  id           Int      @id @default(autoincrement())
  titulo       String
  descripcion  String
  especialidad String
  empresaId    Int
  activa       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  postulaciones Postulacion[]
}

// ─── POSTULACIONES ───────────────────────────────────────────

model Postulacion {
  id           Int      @id @default(autoincrement())
  estudianteId Int
  ofertaId     Int
  estado       EstadoPostulacion @default(PENDIENTE)
  creadoEn     DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
  oferta       Oferta     @relation(fields: [ofertaId], references: [id])
}

enum EstadoPostulacion {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum TipoDisponibilidad {
  PASANTIA
  FREELANCE
  AMBOS
}

enum TipoMedia {
  IMAGEN
  VIDEO
}

// ─── POSTS DEL FEED ──────────────────────────────────────────

model Post {
  id               Int        @id @default(autoincrement())
  contenido        String
  mediaUrl         String?
  mediaType        TipoMedia?
  autorTipo        Rol        @default(ESTUDIANTE)
  estudianteId     Int?
  empresaId        Int?
  administradorId  Int?
  creadoEn         DateTime   @default(now())

  estudiante       Estudiante?    @relation(fields: [estudianteId], references: [id])
  empresa          Empresa?       @relation(fields: [empresaId], references: [id])
  administrador    Administrador? @relation(fields: [administradorId], references: [id])
  comentarios      Comentario[]
}

// ─── CONTACTO DIRECTO (empresa contacta estudiante) ──────────

model Contacto {
  id               Int      @id @default(autoincrement())
  empresaId        Int?
  estudianteId     Int
  mensaje          String?
  nombreRemitente  String?
  emailRemitente   String?
  creadoEn         DateTime @default(now())

  empresa          Empresa?    @relation(fields: [empresaId], references: [id])
  estudiante       Estudiante  @relation(fields: [estudianteId], references: [id])
}

// ─── COMENTARIOS DEL FEED ─────────────────────────────────────

model Comentario {
  id              Int      @id @default(autoincrement())
  contenido       String
  postId          Int
  autorTipo       Rol
  estudianteId    Int?
  empresaId       Int?
  administradorId Int?
  creadoEn        DateTime @default(now())

  post            Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  estudiante      Estudiante?    @relation(fields: [estudianteId], references: [id])
  empresa         Empresa?       @relation(fields: [empresaId], references: [id])
  administrador   Administrador? @relation(fields: [administradorId], references: [id])
}

// ─── MENSAJES EMPRESA ↔ COLEGIO ──────────────────────────

model Mensaje {
  id         Int      @id @default(autoincrement())
  empresaId  Int
  contenido  String
  autorTipo  Rol
  leido      Boolean  @default(false)
  creadoEn   DateTime @default(now())

  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

// ─── CONVERSACIONES DIRECTAS (DMs) ───────────────────────────

enum TipoConversacion {
  EMPRESA_ESTUDIANTE
  ESTUDIANTE_ESTUDIANTE
  ADMINISTRADOR_ESTUDIANTE
}

model Conversacion {
  id              Int              @id @default(autoincrement())
  tipo            TipoConversacion
  empresaId       Int?
  administradorId Int?
  estudiante1Id   Int
  estudiante2Id   Int?
  creadoEn        DateTime         @default(now())

  empresa         Empresa?       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  administrador   Administrador? @relation(fields: [administradorId], references: [id], onDelete: Cascade)
  estudiante1     Estudiante     @relation("conv_est1", fields: [estudiante1Id], references: [id])
  estudiante2     Estudiante?    @relation("conv_est2", fields: [estudiante2Id], references: [id])
  mensajes        MensajeDirecto[]
}

model MensajeDirecto {
  id                    Int      @id @default(autoincrement())
  conversacionId        Int
  contenido             String
  autorTipo             Rol
  emisorEmpresaId       Int?
  emisorEstudianteId    Int?
  emisorAdministradorId Int?
  leido                 Boolean  @default(false)
  creadoEn              DateTime @default(now())

  conversacion          Conversacion   @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  emisorEmpresa         Empresa?       @relation("dm_emisor_empresa", fields: [emisorEmpresaId], references: [id])
  emisorEstudiante      Estudiante?    @relation("dm_emisor_estudiante", fields: [emisorEstudianteId], references: [id])
  emisorAdministrador   Administrador? @relation("dm_emisor_admin", fields: [emisorAdministradorId], references: [id])
}
